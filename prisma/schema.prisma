generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  role       String   @default("USER")
  investorId String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  representedClients Client[] @relation("Representative")
}

model Client {
  id               String      @id @default(cuid())
  name             String      @unique
  cnpj             String?
  status           String      @default("ATIVO")
  taxaFator        Float?
  taxaAdValorem    Float?
  taxaTarifa       Float?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  operations       Operation[]
  agreements       Agreement[]
  representativeId String?
  representative   User?       @relation("Representative", fields: [representativeId], references: [id])
}

model Investor {
  id           String                  @id @default(cuid())
  name         String                  @unique
  rate         Float?
  type         String                  @default("RETIRADA")
  startDate    DateTime?               // Data de início / Onboarding
  userId       String?                 @unique
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  transactions InvestmentTransaction[]
}

model InvestmentTransaction {
  id         String   @id @default(cuid())
  investorId String
  investor   Investor @relation(fields: [investorId], references: [id])
  type       String   // APORTE, RETIRADA
  amount     Float
  date       DateTime
  prazo      Int?
  parentId   String?  // ID do Aporte de onde está sendo resgatado
  modalidade String?  // RETIRADA ou REINVESTIMENTO (específico para este aporte)
  rate       Float?   // Taxa de rendimento específica para este aporte
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Cost {
  id        String   @id @default(cuid())
  name      String
  amount    Float
  date      DateTime
  type      String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Operation {
  id                  String   @id @default(cuid())
  clientId            String
  date                DateTime
  valorBruto          Float
  fator               Float
  percentual          Float
  percentualPrazo     Float
  dias                Float
  tarifas             Float
  percentualTarifas   Float?
  adValorem           Float
  percentualAdValorem Float?
  irpj                Float?
  iof                 Float?
  iofAdicional        Float?
  valorLiquido        Float
  recompra            Float?
  declarada           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  client              Client   @relation(fields: [clientId], references: [id])
  sacados             Sacado[]
}

model Sacado {
  id          String   @id @default(cuid())
  operationId String
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  nome        String
  cnpj        String?
  valor       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Agreement {
  id                String                 @id @default(cuid())
  clientId          String
  client            Client                 @relation(fields: [clientId], references: [id])
  totalValue        Float
  installmentsCount Int
  status            String                 @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  installments      AgreementInstallment[]
}

model AgreementInstallment {
  id            String    @id @default(cuid())
  agreementId   String
  agreement     Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  value         Float
  dueDate       DateTime
  status        String    @default("PENDING") // PENDING, PAID
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model GlobalSettings {
  id                  String   @id @default(cuid())
  defaultFator        Float?
  defaultAdValorem    Float?
  defaultIof          Float?
  defaultIofAdicional Float?
  defaultTarifas      Json?
  updatedAt           DateTime @updatedAt
}
